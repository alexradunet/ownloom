FROM docker.io/library/debian:bookworm-slim AS source

ARG FLUFFYCHAT_VERSION=v2.3.1

RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl tar \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src
RUN curl -fsSL "https://github.com/krille-chan/fluffychat/archive/refs/tags/${FLUFFYCHAT_VERSION}.tar.gz" \
    | tar -xz --strip-components=1

FROM ghcr.io/cirruslabs/flutter:stable AS builder

WORKDIR /app
COPY --from=source /src /app

RUN apt-get update && apt-get install -y --no-install-recommends curl wget jq build-essential \
    && rm -rf /var/lib/apt/lists/*
RUN wget -q https://github.com/mikefarah/yq/releases/download/v4.40.5/yq_linux_amd64.tar.gz
RUN tar -xzf yq_linux_amd64.tar.gz
RUN mv yq_linux_amd64 /usr/bin/yq
RUN curl https://sh.rustup.rs -sSf | bash -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"
RUN rustup component add rust-src --toolchain nightly-x86_64-unknown-linux-gnu
RUN ./scripts/prepare-web.sh
# FluffyChat's upstream dev-only desktop tooling currently conflicts with the
# Flutter SDK in this builder image. Drop those packages and align lint rules
# before resolving dependencies for the web artifact.
RUN yq -i 'del(.dev_dependencies.license_checker, .dev_dependencies.msix) | .dev_dependencies.flutter_lints = "^6.0.0"' pubspec.yaml
RUN flutter pub get
RUN flutter build web --dart-define=FLUTTER_WEB_CANVASKIT_URL=canvaskit/ --release --source-maps

FROM docker.io/nginx:alpine

RUN rm -rf /usr/share/nginx/html/*
COPY --from=builder /app/build/web /usr/share/nginx/html
EXPOSE 80
