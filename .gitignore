# Nix build outputs
result
result-*

# Local agent/session state
.codex
.pi/

# Real SOPS config is created when the actual age recipient exists.
.sops.yaml
!.sops.example.yaml

# Node / test artifacts
node_modules
coverage
dist-test
dist
os/pkgs/nixpi-wiki/extension
os/pkgs/nixpi-wiki/core

# Wiki lives outside the repo at ~/wiki — gitignore the whole dir as a
# safety net in case someone accidentally clones it here.
wiki/

# Host-local private overlays are TRACKED with placeholder values, not
# gitignored. After cloning, fill them in with real values and run
# `git update-index --skip-worktree hosts/nixpi-vps/*.private.nix`
# to keep local edits out of commits.

# Real encrypted SOPS files are intentionally added explicitly when ready.
hosts/*/secrets.yaml
!hosts/nixpi-vps/secrets.yaml
!hosts/*/secrets.example.yaml
