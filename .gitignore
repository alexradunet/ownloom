# Nix build outputs
result
result-*

# Local agent/session state
.codex
.pi/

# Real SOPS config is created when the actual age recipient exists.
.sops.yaml
!.sops.example.yaml

# Node / test artifacts
node_modules
coverage
dist-test
dist
os/pkgs/gateway-web/public/generated/
os/pkgs/wiki/extension
os/pkgs/wiki/core

# Wiki lives outside the repo at ~/wiki — ignore only a root wiki dir as a
# safety net in case someone accidentally clones one here. Do not ignore the
# tracked os/pkgs/wiki package or future source files under os/pkgs/wiki/src/wiki.
/wiki/

# Host-local private overlays are TRACKED with placeholder values, not
# gitignored. After cloning, fill them in with real values and run
# `git update-index --skip-worktree hosts/ownloom-vps/*.private.nix`
# to keep local edits out of commits.

# Real encrypted SOPS files are intentionally added explicitly when ready.
hosts/*/secrets.yaml
!hosts/ownloom-vps/secrets.yaml
!hosts/*/secrets.example.yaml
