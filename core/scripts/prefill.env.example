# Bloom wizard prefill — copy to core/scripts/prefill.env and fill in values.
# just vm will stage it automatically; any variable left unset will still prompt.

PREFILL_NETBIRD_KEY=your-netbird-setup-key-here
PREFILL_NAME="Your Name"
PREFILL_EMAIL="you@example.com"
PREFILL_USERNAME=yourmatrixusername
# Matrix password - when installed via Calamares, this defaults to your OS password
# (set automatically in ~/.bloom/prefill.env during installation)
PREFILL_MATRIX_PASSWORD=yourpassword
PREFILL_PI_PASSWORD=yourpassword
